# ================================================
# Configuração de PRODUÇÃO para o backend
# ================================================
# Copie este arquivo para .env e edite os valores:
#   cp .env.production.example .env
#   nano .env
# ================================================

PORT=3001
HOST=0.0.0.0
DATABASE_FILE=database/gestao_obras.db
NODE_ENV=production

# OBRIGATÓRIO: troque por uma chave aleatória forte.
# Gere com:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_AQUI_POR_UMA_CHAVE_ALEATORIA_FORTE
